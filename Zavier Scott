<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>⭐ SKY DASH ⭐</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            background: #0a0a1f;
            color: white;
            font-family: 'Press Start 2P', cursive;
            text-align: center;
            overflow: hidden;
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        h1 { font-size: 2.6rem; background: linear-gradient(90deg, #00ffcc, #ffff00); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-shadow: 0 0 40px #00ffcc; }
        .score { font-size: 1.1rem; margin: 6px 10px; padding: 8px 20px; background: rgba(0,255,204,0.1); border: 3px solid #00ffcc; border-radius: 10px; display: inline-block; }
        canvas { border: 8px solid #00ffcc; border-radius: 20px; box-shadow: 0 0 60px #00ffcc; image-rendering: pixelated; }
        .menu, .game-over, .shop { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(10,15,45,0.97); padding: 25px; border: 8px solid #00ffcc; border-radius: 20px; z-index: 200; display: none; flex-direction: column; align-items: center; gap: 12px; }
        button { padding: 12px 30px; font-family: 'Press Start 2P', cursive; background: linear-gradient(#ff0066,#cc0044); color:white; border:none; border-radius:10px; cursor:pointer; }
        button:hover { transform:scale(1.08); }
        .skin-preview { width:60px; height:60px; border:3px solid #fff; border-radius:50%; }
    </style>
</head>
<body>
    <header>
        <h1>⭐ SKY DASH ⭐</h1>
        <div class="score">SCORE: <span id="score">0</span></div>
        <div class="score">COINS: <span id="coins">0</span></div>
        <div class="score">HIGH: <span id="highscore">0</span></div>
    </header>
    
    <canvas id="game" width="420" height="620"></canvas>

    <!-- Title -->
    <div id="menu" class="menu">
        <h2 style="color:#ffff00">READY TO FLY?</h2>
        <button onclick="startGame()">PLAY</button>
        <button onclick="showShop()">SHOP / SKINS</button>
        <p style="font-size:0.8rem">TAP / SPACE to flap</p>
    </div>

    <!-- Game Over -->
    <div id="gameOver" class="game-over">
        <h2 style="color:#ff3366">CRASHED!</h2>
        <p>SCORE: <span id="finalScore">0</span></p>
        <p>COINS EARNED: <span id="coinsEarned">0</span></p>
        <button onclick="restartGame()">PLAY AGAIN</button>
        <button onclick="showShop()">SHOP</button>
        <button onclick="shareScore()">SHARE</button>
    </div>

    <!-- Shop -->
    <div id="shop" class="shop">
        <h2 style="color:#ffff00">SKINS & BOOSTS</h2>
        <div id="skinList" style="display:flex; gap:15px; flex-wrap:wrap; justify-content:center;"></div>
        <button onclick="buyBoost()" style="background:#00cc66">BOOST (+20 PIPES) — 50 COINS</button>
        <button onclick="closeShop()">CLOSE</button>
    </div>

    <div class="ad-placeholder" style="margin-top:15px; padding:10px; background:rgba(255,255,255,0.06); border:2px dashed #555; width:728px; max-width:95%; height:90px;">
        [ ADSENSE HERE ]
    </div>

    <script>
        const canvas = document.getElementById('game');
        const ctx = canvas.getContext('2d');
        const scoreEl = document.getElementById('score');
        const coinsEl = document.getElementById('coins');
        const highscoreEl = document.getElementById('highscore');
        
        const GAP = 165;
        let bird = { x: 90, y: 280, velocity: 0, radius: 19, gravity: 0.65, flap: -13.5, wingFrame: 0 };
        let pipes = [], stars = [], particles = [], scorePopups = [];
        let score = 0, coins = parseInt(localStorage.getItem('skyDashCoins')) || 0, highScore = parseInt(localStorage.getItem('skyDashHigh')) || 0;
        let frame = 0, gameRunning = false, paused = false, shake = 0;
        let currentSkin = localStorage.getItem('skyDashSkin') || 'golden';
        let unlockedSkins = JSON.parse(localStorage.getItem('skyDashUnlocked')) || ['golden'];
        let audioContext = null, musicOsc = null, musicGain = null;

        highscoreEl.textContent = highScore;
        coinsEl.textContent = coins;

        // Skins
        const skins = {
            golden: { body: '#ffeb3b', wing: '#ff9800', beak: '#ff5722' },
            blue: { body: '#4fc3f7', wing: '#0277bd', beak: '#ff9800' },
            red: { body: '#ef5350', wing: '#c62828', beak: '#ffeb3b' },
            purple: { body: '#ba68c8', wing: '#7b1fa2', beak: '#ffeb3b' }
        };

        function getAudioContext() {
            if (!audioContext) audioContext = new (window.AudioContext || window.webkitAudioContext)();
            return audioContext;
        }

        function startMusic() {
            try {
                const ctx = getAudioContext();
                musicOsc = ctx.createOscillator();
                musicGain = ctx.createGain();
                musicOsc.type = 'sawtooth';
                musicOsc.frequency.value = 220;
                musicGain.gain.value = 0.08;
                const filter = ctx.createBiquadFilter();
                filter.type = 'lowpass'; filter.frequency.value = 800;
                musicOsc.connect(filter).connect(musicGain).connect(ctx.destination);
                musicOsc.start();
            } catch(e) {}
        }

        function playSound(freq, duration, type='sine', vol=0.4) {
            try {
                const ctx = getAudioContext();
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.type = type; osc.frequency.value = freq;
                gain.gain.value = vol;
                osc.connect(gain).connect(ctx.destination);
                osc.start(); osc.stop(ctx.currentTime + duration);
            } catch(e) {}
        }

        function createParticles(x, y, color, count) {
            for (let i = 0; i < count; i++) {
                particles.push({x, y, vx: (Math.random()-0.5)*8, vy: (Math.random()-0.5)*8-2, life: 30, color, size: 6});
            }
        }

        function createScorePopup(x, y, points) {
            scorePopups.push({x, y: y-25, points, life: 50, vy: -1.6});
        }

        function drawBackground() {
            const grad = ctx.createLinearGradient(0,0,0,canvas.height);
            grad.addColorStop(0,'#1a0b3d'); grad.addColorStop(1,'#0a0a2e');
            ctx.fillStyle = grad; ctx.fillRect(0,0,canvas.width,canvas.height);
            
            // Mountains
            ctx.fillStyle = '#1f1b4d';
            ctx.beginPath(); ctx.moveTo(0,canvas.height-100); ctx.lineTo(140,220); ctx.lineTo(300,canvas.height-130); ctx.lineTo(canvas.width,canvas.height-70); ctx.lineTo(0,canvas.height); ctx.fill();
            
            // Stars
            ctx.fillStyle = '#fff';
            for (let i = 0; i < 45; i++) {
                const x = (i*33 + frame*0.2) % (canvas.width+80) - 30;
                ctx.globalAlpha = 0.4 + Math.sin(frame/20 + i)*0.3;
                ctx.fillRect(x, 60 + (i%11)*45, 3, 3);
            }
            ctx.globalAlpha = 1;
        }

        function drawBird() {
            const skin = skins[currentSkin];
            ctx.save();
            ctx.translate(bird.x, bird.y);
            ctx.rotate(Math.min(Math.max(bird.velocity * 0.06, -0.65), 1.3));
            
            ctx.shadowBlur = 25; ctx.shadowColor = skin.body;
            ctx.fillStyle = skin.body;
            ctx.beginPath(); ctx.ellipse(0,0,bird.radius,bird.radius*0.9,0,0,Math.PI*2); ctx.fill();
            
            bird.wingFrame = (bird.wingFrame + 0.35) % 6.28;
            const wing = Math.sin(bird.wingFrame)*0.65;
            ctx.fillStyle = skin.wing;
            ctx.save(); ctx.rotate(wing); ctx.beginPath(); ctx.ellipse(-5,5,17,10,0,0,Math.PI*2); ctx.fill(); ctx.restore();
            
            // Eye
            ctx.shadowBlur = 10; ctx.shadowColor = '#fff';
            ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(11,-7,8,0,Math.PI*2); ctx.fill();
            ctx.fillStyle = '#111'; ctx.beginPath(); ctx.arc(13,-7,4.5,0,Math.PI*2); ctx.fill();
            
            ctx.fillStyle = skin.beak;
            ctx.beginPath(); ctx.moveTo(23,0); ctx.lineTo(33,-7); ctx.lineTo(33,7); ctx.fill();
            ctx.restore();
        }

        function generatePipe() { 
            const height = 80 + Math.random() * (canvas.height - GAP - 190);
            pipes.push({x: canvas.width+30, top: height, bottomY: height+GAP, passed: false});
        }

        function generateStar() {
            if (Math.random() < 0.6) stars.push({x: canvas.width+40, y: 130 + Math.random()*(canvas.height-300), collected: false, pulse: 0});
        }

        function update() {
            if (!gameRunning || paused) return;
            frame++;
            
            bird.velocity += bird.gravity;
            bird.y += bird.velocity;
            
            if (bird.y + bird.radius > canvas.height - 55 || bird.y - bird.radius < 25) endGame();
            
            for (let i = pipes.length-1; i >= 0; i--) {
                const p = pipes[i]; p.x -= 3;
                if (!p.passed && p.x + 55 < bird.x) {
                    p.passed = true; score += 10; scoreEl.textContent = score;
                    coins += 1; coinsEl.textContent = coins;
                    playSound(880,0.08);
                }
                if (bird.x + bird.radius > p.x && bird.x - bird.radius < p.x+68) {
                    if (bird.y - bird.radius < p.top || bird.y + bird.radius > p.bottomY) endGame();
                }
                if (p.x < -100) pipes.splice(i,1);
            }
            
            for (let i = stars.length-1; i >= 0; i--) {
                const s = stars[i]; s.x -= 3; s.pulse += 0.25;
                if (Math.hypot(bird.x-s.x, bird.y-s.y) < 38 && !s.collected) {
                    s.collected = true; score += 25; coins += 3;
                    scoreEl.textContent = score; coinsEl.textContent = coins;
                    playSound(1400,0.15); createParticles(s.x,s.y,'#ffff00',22);
                }
                if (s.x < -40) stars.splice(i,1);
            }
            
            // Particles & popups update...
            for (let i=particles.length-1;i>=0;i--) { const p=particles[i]; p.x+=p.vx; p.y+=p.vy; p.vy+=0.35; p.life--; if(p.life<=0) particles.splice(i,1); }
            for (let i=scorePopups.length-1;i>=0;i--) { const p=scorePopups[i]; p.y+=p.vy; p.life--; if(p.life<=0) scorePopups.splice(i,1); }
            
            if (frame % 62 === 0) generatePipe();
            if (frame % 45 === 0) generateStar();
            
            // Unlock skins
            if (score >= 100 && !unlockedSkins.includes('blue')) unlockSkin('blue');
            if (score >= 300 && !unlockedSkins.includes('red')) unlockSkin('red');
            if (score >= 600 && !unlockedSkins.includes('purple')) unlockSkin('purple');
        }

        function unlockSkin(name) {
            unlockedSkins.push(name);
            localStorage.setItem('skyDashUnlocked', JSON.stringify(unlockedSkins));
        }

        function drawPipes() { /* same improved pipes as before */ 
            for (let p of pipes) {
                const g = ctx.createLinearGradient(p.x,0,p.x+68,0);
                g.addColorStop(0,'#22c55e'); g.addColorStop(1,'#15803d');
                ctx.fillStyle = g; ctx.fillRect(p.x,0,68,p.top);
                ctx.fillStyle = 'rgba(255,255,255,0.35)'; ctx.fillRect(p.x+6,0,14,p.top);
                ctx.fillStyle = '#22c55e'; ctx.fillRect(p.x-8,p.top-40,84,40);
                
                const by = p.bottomY;
                ctx.fillStyle = g; ctx.fillRect(p.x,by,68,canvas.height-by);
                ctx.fillStyle = 'rgba(255,255,255,0.35)'; ctx.fillRect(p.x+6,by,14,canvas.height-by);
                ctx.fillRect(p.x-8,by,84,40);
            }
        }

        function drawStars() { /* glowing stars */ 
            for (let s of stars) {
                if (s.collected) continue;
                const sz = Math.sin(s.pulse)*3 + 12;
                ctx.shadowBlur = 30; ctx.shadowColor = '#ffff00';
                ctx.fillStyle = '#ffff00';
                ctx.save(); ctx.translate(s.x,s.y); ctx.rotate(frame/6);
                ctx.fillRect(-sz/2,-4,sz,8); ctx.fillRect(-4,-sz/2,8,sz);
                ctx.restore(); ctx.shadowBlur=0;
            }
        }

        function draw() {
            const sx = shake ? (Math.random()-0.5)*shake : 0;
            ctx.save(); ctx.translate(sx,0);
            drawBackground(); drawPipes(); drawStars(); drawBird();
            // particles & popups drawing (same as previous versions)
            ctx.restore();
        }

        function gameLoop() { update(); draw(); requestAnimationFrame(gameLoop); }

        function flap() {
            if (gameRunning) bird.velocity = bird.flap;
            playSound(580, 0.07, 'triangle', 0.6);
        }

        function startGame() {
            document.getElementById('menu').style.display = 'none';
            gameRunning = true; resetGame(); startMusic();
        }

        function resetGame() {
            bird.y = 280; bird.velocity = -3;
            pipes = []; stars = []; particles = []; scorePopups = [];
            score = 0; frame = 0;
            scoreEl.textContent = '0';
            generatePipe(); generatePipe();
        }

        function endGame() {
            gameRunning = false; shake = 20;
            playSound(160,0.9,'sawtooth',0.7);
            if (score > highScore) { highScore = score; localStorage.setItem('skyDashHigh', highScore); }
            localStorage.setItem('skyDashCoins', coins);
            document.getElementById('finalScore').textContent = score;
            document.getElementById('coinsEarned').textContent = Math.floor(score/8);
            document.getElementById('gameOver').style.display = 'flex';
        }

        function restartGame() { document.getElementById('gameOver').style.display = 'none'; resetGame(); gameRunning = true; }

        function showShop() {
            document.getElementById('shop').style.display = 'flex';
            const list = document.getElementById('skinList');
            list.innerHTML = '';
            Object.keys(skins).forEach(key => {
                const div = document.createElement('div');
                div.style.cursor = 'pointer';
                div.onclick = () => { if (unlockedSkins.includes(key)) currentSkin = key; localStorage.setItem('skyDashSkin', currentSkin); };
                div.innerHTML = `<div class="skin-preview" style="background:${skins[key].body}"></div><small>${key}</small>`;
                list.appendChild(div);
            });
        }

        function closeShop() { document.getElementById('shop').style.display = 'none'; }

        function buyBoost() {
            if (coins >= 50) {
                coins -= 50; coinsEl.textContent = coins;
                // Skip 20 pipes
                for (let i = 0; i < 20; i++) {
                    if (pipes.length > 0) pipes.shift();
                }
                playSound(1200,0.3); createParticles(bird.x+30, bird.y, '#00ff88', 30);
            } else {
                alert("Not enough coins!");
            }
        }

        function shareScore() { /* same as before */ }

        // Controls
        document.addEventListener('keydown', e => {
            if (e.key === ' ' || e.key === 'ArrowUp') { e.preventDefault(); flap(); }
            if (e.key.toLowerCase() === 'p') paused = !paused;
        });
        canvas.addEventListener('click', flap);
        canvas.addEventListener('touchstart', e => { e.preventDefault(); flap(); });

        document.getElementById('menu').style.display = 'flex';
        gameLoop();
    </script>
</body>
</html>
